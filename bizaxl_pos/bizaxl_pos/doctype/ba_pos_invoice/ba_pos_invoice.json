{
 "name": "BA POS Invoice",
 "doctype": "DocType",
 "module": "BizAxl POS",
 "naming_rule": "By \"Naming Series\" field",
 "autoname": "naming_series",
 "is_submittable": 1,
 "track_changes": 1,
 "fields": [
  {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "BA-POS-.YYYY.-", "reqd": 1},
  {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "BA Customer"},
  {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1},
  {"fieldname": "pos_profile", "fieldtype": "Link", "label": "POS Profile", "options": "BA POS Profile"},
  {"fieldname": "col1", "fieldtype": "Column Break"},
  {"fieldname": "posting_date", "fieldtype": "Date", "label": "Date", "reqd": 1, "default": "Today"},
  {"fieldname": "posting_time", "fieldtype": "Time", "label": "Time"},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "BA Company", "reqd": 1},
  {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "BA Currency"},
  {"fieldname": "sec_items", "fieldtype": "Section Break", "label": "Items"},
  {"fieldname": "items", "fieldtype": "Table", "label": "Items", "options": "BA POS Invoice Item", "reqd": 1},
  {"fieldname": "sec_tax", "fieldtype": "Section Break", "label": "Tax"},
  {"fieldname": "taxes_and_charges", "fieldtype": "Link", "label": "Tax Template", "options": "BA Tax Template"},
  {"fieldname": "total_taxes", "fieldtype": "Currency", "label": "Total Taxes", "read_only": 1},
  {"fieldname": "sec_totals", "fieldtype": "Section Break", "label": "Totals"},
  {"fieldname": "net_total", "fieldtype": "Currency", "label": "Net Total", "read_only": 1},
  {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total", "read_only": 1},
  {"fieldname": "outstanding_amount", "fieldtype": "Currency", "label": "Outstanding", "read_only": 1},
  {"fieldname": "col2", "fieldtype": "Column Break"},
  {"fieldname": "paid_amount", "fieldtype": "Currency", "label": "Paid Amount"},
  {"fieldname": "change_amount", "fieldtype": "Currency", "label": "Change", "read_only": 1},
  {"fieldname": "sec_payments", "fieldtype": "Section Break", "label": "Payments"},
  {"fieldname": "payments", "fieldtype": "Table", "label": "Payment Methods", "options": "BA POS Payment"},
  {"fieldname": "sec_accounts", "fieldtype": "Section Break", "label": "Accounting"},
  {"fieldname": "debit_to", "fieldtype": "Link", "label": "Debit To", "options": "BA Account"},
  {"fieldname": "cashier_shift", "fieldtype": "Link", "label": "Cashier Shift", "options": "Cashier Shift"},
  {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nPaid\nUnpaid\nCancelled", "read_only": 1}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1},
  {"role": "Accounts Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
  {"role": "Accounts User", "read": 1, "write": 1, "create": 1, "submit": 1},
  {"role": "HR User", "read": 1, "write": 1, "create": 1, "submit": 1}
 ]
}
